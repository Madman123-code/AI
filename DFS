# Depth First Search (DFS) for an undirected graph with user input

def dfs(graph, vertex, visited):
    visited.add(vertex)
    print(vertex, end=' ')

    for neighbor in graph.get(vertex, []):
        if neighbor not in visited:
            dfs(graph, neighbor, visited)

